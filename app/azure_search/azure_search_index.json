{
  "name": "student-index",
  "fields": [
    { "name": "id", "type": "Edm.String", "key": true, "filterable": true },
    { "name": "student_id", "type": "Edm.String", "filterable": true },
    { "name": "pen", "type": "Edm.String", "filterable": true },

    { "name": "legalFirstName", "type": "Edm.String", "searchable": true },
    { "name": "legalMiddleNames", "type": "Edm.String", "searchable": true },
    { "name": "legalLastName", "type": "Edm.String", "searchable": true },

    { "name": "content", "type": "Edm.String", "searchable": true },

    {
      "name": "nameEmbedding",
      "type": "Collection(Edm.Single)",
      "searchable": true,
      "dimensions": 3072,
      "vectorSearchProfile": "vector-profile"
    },

    { "name": "dob", "type": "Edm.String", "filterable": true },
    { "name": "sexCode", "type": "Edm.String", "filterable": true },
    { "name": "postalCode", "type": "Edm.String", "filterable": true },
    { "name": "mincode", "type": "Edm.String", "filterable": true },

    { "name": "grade", "type": "Edm.String", "filterable": true },
    { "name": "localID", "type": "Edm.String", "filterable": true }
  ],

  "scoringProfiles": [
    {
      "name": "identity-ranking",
      "textWeights": {
        "weights": {
          "legalFirstName": 3,
          "legalLastName": 3,
          "legalMiddleNames": 2,
          "content": 1
        }
      }
    }
  ],

  "vectorSearch": {
    "profiles": [
      { "name": "vector-profile", "algorithm": "hnsw-algorithm" }
    ],
    "algorithms": [
      {
        "name": "hnsw-algorithm",
        "kind": "hnsw",
        "hnswParameters": {
          "m": 16,
          "efConstruction": 200
        }
      }
    ]
  }
}